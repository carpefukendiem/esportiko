# Supabase (Team portal auth + database + storage)
# Vercel: add these under Project → Settings → Environment Variables for Production
# (and Preview). Redeploy after adding — NEXT_PUBLIC_* values are baked in at build time.
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# Site URL for OAuth redirects and portal links (no trailing slash).
# Production: your real https origin. Add in Supabase Dashboard → Auth → URL config:
#   Redirect URLs: https://YOUR_DOMAIN/auth/callback
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# GoHighLevel — portal order submissions (single webhook)
GHL_WEBHOOK_URL=

# Google sign-in is enabled in Supabase Dashboard → Auth → Providers (not via app env).

# Legacy / other GHL form webhooks (public site forms)
GHL_WEBHOOK_URL_TEAM_ORDER=
GHL_WEBHOOK_URL_BUSINESS_ORDER=
GHL_WEBHOOK_URL_CONTACT=
GHL_WEBHOOK_URL_TEAM_ROSTER_DETAILS=
GHL_API_KEY=

# Team portal chat widget (optional)
GHL_LOCATION_ID=
