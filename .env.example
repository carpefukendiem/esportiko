# Supabase (Team portal auth + database + storage)
# Vercel: add these under Project → Settings → Environment Variables for Production
# (and Preview). Redeploy after adding — NEXT_PUBLIC_* values are baked in at build time.
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# SanMar SFTP (nightly EPDD) — credentials from SanMar integration email (not web services)
SANMAR_FTP_HOST=ftp.sanmar.com
SANMAR_FTP_PORT=2200
SANMAR_FTP_USER=
SANMAR_FTP_PASSWORD=

# Vercel Cron: Authorization: Bearer <secret> for /api/cron/sync-sanmar
CRON_SECRET=

# Site URL for OAuth redirects and portal links (no trailing slash).
# Production: your real https origin. Add in Supabase Dashboard → Auth → URL config:
#   Redirect URLs: https://YOUR_DOMAIN/auth/callback
#   Also add: https://YOUR_DOMAIN/reset-password (password recovery email link)
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# Admin UI (/admin): comma-separated emails allowed to access admin routes (server).
ADMIN_EMAILS=ruben@example.com
# Same list for showing the "Admin" link in the portal sidebar (client). Keep in sync with ADMIN_EMAILS.
NEXT_PUBLIC_ADMIN_EMAILS=ruben@example.com

# Optional: customer emails from admin UI (lib/actions/admin-messaging.ts)
# RESEND_API_KEY=
# RESEND_FROM_EMAIL="Esportiko <orders@yourdomain.com>"

# GoHighLevel — portal order submissions (single webhook)
GHL_WEBHOOK_URL=

# Google sign-in is enabled in Supabase Dashboard → Auth → Providers (not via app env).

# Legacy / other GHL form webhooks (public site forms)
GHL_WEBHOOK_URL_TEAM_ORDER=
GHL_WEBHOOK_URL_BUSINESS_ORDER=
GHL_WEBHOOK_URL_CONTACT=
GHL_WEBHOOK_URL_TEAM_ROSTER_DETAILS=
GHL_API_KEY=

# Team portal chat widget (optional)
GHL_LOCATION_ID=
